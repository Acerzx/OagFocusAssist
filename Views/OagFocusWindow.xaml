<Window x:Class="OagFocusAssist.Views.OagFocusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔭 OAG Manual Focus Assistant"
        Height="510" Width="675"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#E4E4E7"
        Topmost="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 0: ГРАФИК                          -->
        <!-- ═══════════════════════════════════════ -->
        <Border x:Name="GraphBorder" Grid.Row="0"
                Background="#2A2A3E"
                BorderBrush="#3F3F46"
                BorderThickness="3"
                CornerRadius="6"
                ClipToBounds="True"
                MinHeight="220">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5"/>
            </Border.RenderTransformOrigin>
            <Viewbox Stretch="Uniform" StretchDirection="Both">
                <Grid Width="650" Height="260">
                    <Polyline Points="{Binding GraphPoints}"
                              Stroke="#5B8DEF"
                              StrokeThickness="2.5"
                              StrokeLineJoin="Round"/>
                    <ItemsControl ItemsSource="{Binding GraphPoints}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Ellipse Width="7" Height="7" Fill="#5B8DEF" Margin="-3.5,-3.5,0,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding MinPoint}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Ellipse Width="14" Height="14" Fill="Transparent"
                                         Stroke="#FBBF24" StrokeThickness="2" Margin="-7,-7,0,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- OVERLAY: компактная плашка с именем камеры и статусом    -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Border Background="#CC1E1E2E" CornerRadius="6" Padding="18,10"
                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Имя камеры -->
                            <TextBlock Text="{Binding CameraName}"
                                       Foreground="#A1A1AA" FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <!-- Номер кадра (без приписки "Кадр") -->
                            <TextBlock Text="{Binding FrameCount}"
                                       Foreground="#E4E4E7" FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <!-- Разделитель -->
                            <TextBlock Text="•" Foreground="#52525B" FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <!-- СТАТУС: цвет привязан к TrendBrush (динамический) -->
                            <TextBlock Text="{Binding TrendText}"
                                       Foreground="{Binding TrendBrush}" FontSize="17" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Viewbox>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 1: СТАТИСТИКА                       -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="6" Padding="14,10" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="ТЕКУЩИЙ HFR" Foreground="#A1A1AA" FontSize="10"
                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CurrentHfr, StringFormat={}{0:F2}}"
                               Foreground="#5B8DEF" FontSize="34" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#2A2A3E" CornerRadius="6" Padding="14,10" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="СРЕДНИЙ HFR" Foreground="#A1A1AA" FontSize="10"
                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding AverageHfr, StringFormat={}{0:F2}}"
                               Foreground="#4ADE80" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="6" Padding="10,4">
                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MIN " Foreground="#A1A1AA" FontSize="10"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding MinHfr, StringFormat={}{0:F2}}"
                                   Foreground="#FBBF24" FontSize="22" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Separator Grid.Row="1" Background="#3F3F46" Margin="0,2"/>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MAX " Foreground="#A1A1AA" FontSize="10"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding MaxHfr, StringFormat={}{0:F2}}"
                                   Foreground="#F87171" FontSize="22" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 2: ПРЕСЕТЫ + ПОЛЕ + КНОПКИ          -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                <TextBlock Text="Пресеты экспозиции:" Foreground="#A1A1AA" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="0.1" Command="{Binding SetExposureCommand}" CommandParameter="0.1"
                        Width="40" Height="22" Margin="0,0,4,0"
                        Background="#3F3F46" Foreground="#E4E4E7" BorderThickness="0" FontSize="11" Cursor="Hand"/>
                <Button Content="0.2" Command="{Binding SetExposureCommand}" CommandParameter="0.2"
                        Width="40" Height="22" Margin="0,0,4,0"
                        Background="#3F3F46" Foreground="#E4E4E7" BorderThickness="0" FontSize="11" Cursor="Hand"/>
                <Button Content="0.5" Command="{Binding SetExposureCommand}" CommandParameter="0.5"
                        Width="40" Height="22" Margin="0,0,4,0"
                        Background="#3F3F46" Foreground="#E4E4E7" BorderThickness="0" FontSize="11" Cursor="Hand"/>
                <Button Content="1.0" Command="{Binding SetExposureCommand}" CommandParameter="1.0"
                        Width="40" Height="22"
                        Background="#3F3F46" Foreground="#E4E4E7" BorderThickness="0" FontSize="11" Cursor="Hand"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="4" Padding="6,4"
                        Margin="0,0,10,0" VerticalAlignment="Stretch">
                    <TextBox Text="{Binding ExposureTime, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                             Width="60" Padding="4,2" FontSize="13" FontWeight="SemiBold"
                             Background="#1E1E2E" Foreground="#5B8DEF"
                             BorderBrush="#3F3F46" BorderThickness="1"
                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </Border>

                <!-- Кнопка PLAY -->
                <Button x:Name="PlayButton" Grid.Column="1"
                        Command="{Binding StartSeriesCommand}"
                        Width="90" Margin="0,0,4,0"
                        RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#10B981"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="5" Padding="0,14">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="▶" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="PLAY" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#059669"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayEnabled}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#52525B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#52525B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Кнопка PAUSE -->
                <Button x:Name="PauseButton" Grid.Column="2"
                        Command="{Binding PauseSeriesCommand}"
                        Width="100" Margin="0,0,6,0"
                        RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#F59E0B"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="5" Padding="0,14">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="⏸" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="PAUSE" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#D97706"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPauseEnabled}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#52525B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Кнопка ЗАКОНЧИТЬ -->
                <Button x:Name="FinishButton" Grid.Column="3"
                        Content="ЗАКОНЧИТЬ"
                        Command="{Binding CompleteCommand}"
                        Margin="0,0,0,0"
                        RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#EF4444"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="5" Padding="0,14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>